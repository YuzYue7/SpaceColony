<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <corners android:radius="16dp" />
            <solid android:color="#1A3255" />
            <stroke android:width="1dp" android:color="#355D8D" />
        </shape>
    </item>
    <item>
        <shape>
            <corners android:radius="16dp" />
            <solid android:color="@color/sc_surface_alt" />
            <stroke android:width="1dp" android:color="@color/sc_surface_line" />
        </shape>
    </item>
</selector>