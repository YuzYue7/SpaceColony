<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvStatisticsTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Statistics"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/tvColonyStatsTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Colony Summary"
            android:textStyle="bold"
            android:textSize="18sp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvColonyStats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Colony statistics will appear here"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Performance Overview"
            android:textStyle="bold"
            android:textSize="18sp"
            android:layout_marginBottom="8dp" />

        <com.github.mikephil.charting.charts.BarChart
            android:id="@+id/barChartStats"
            android:layout_width="match_parent"
            android:layout_height="260dp"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Crew Location Distribution"
            android:textStyle="bold"
            android:textSize="18sp"
            android:layout_marginBottom="8dp" />

        <com.github.mikephil.charting.charts.PieChart
            android:id="@+id/pieChartLocations"
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:layout_marginBottom="20dp" />

        <TextView
            android:id="@+id/tvCrewStatsTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Crew Statistics"
            android:textStyle="bold"
            android:textSize="18sp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvCrewStats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Crew statistics will appear here"
            android:layout_marginBottom="20dp" />

        <Button
            android:id="@+id/btnRefreshStatistics"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Refresh Statistics"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnBackHomeFromStatistics"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Back to Home" />

    </LinearLayout>
</ScrollView>