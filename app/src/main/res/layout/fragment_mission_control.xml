<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_gradient"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvMissionTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mission Control"
        android:textColor="@color/sc_text_primary"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvMissionHint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="14dp"
        android:text="Select 2 to 3 crew members and launch a mission"
        android:textColor="@color/sc_text_secondary"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_card"
        android:orientation="vertical"
        android:padding="14dp">

        <Button
            android:id="@+id/btnLaunchMission"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:background="@drawable/bg_button_primary"
            android:text="Launch Mission"
            android:textAllCaps="false"
            android:textColor="@color/sc_text_on_primary"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnReturnToQuartersFromMission"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_button_secondary"
            android:text="Return Selected to Quarters"
            android:textAllCaps="false"
            android:textColor="@color/sc_text_primary"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnBackHomeFromMission"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_button_secondary"
            android:text="Back to Home"
            android:textAllCaps="false"
            android:textColor="@color/sc_text_primary"
            android:textStyle="bold" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerMissionCrew"
        android:layout_width="match_parent"
        android:layout_height="190dp"
        android:clipToPadding="false"
        android:paddingBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_card"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Threat Status"
            android:textColor="@color/sc_text_secondary"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvThreatInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Threat info will appear here"
            android:textColor="@color/sc_text_primary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Current Turn"
            android:textColor="@color/sc_text_secondary"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvCurrentActor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Current actor will appear here"
            android:textColor="@color/sc_text_primary"
            android:textSize="15sp" />

        <LinearLayout
            android:id="@+id/layoutActionButtons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal"
            android:visibility="gone"
            android:weightSum="3">

            <Button
                android:id="@+id/btnAttack"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_button_danger"
                android:text="Attack"
                android:textAllCaps="false"
                android:textColor="@color/sc_text_on_primary"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnDefend"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginStart="3dp"
                android:layout_marginEnd="3dp"
                android:background="@drawable/bg_button_secondary"
                android:text="Defend"
                android:textAllCaps="false"
                android:textColor="@color/sc_text_primary"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnSpecial"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_button_primary"
                android:text="Special"
                android:textAllCaps="false"
                android:textColor="@color/sc_text_on_primary"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/tvMissionLogTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="8dp"
        android:text="Mission Log"
        android:textColor="@color/sc_text_primary"
        android:textSize="18sp"
        android:textStyle="bold" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/bg_card"
        android:padding="14dp">

        <TextView
            android:id="@+id/tvMissionLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No mission launched yet."
            android:textColor="@color/sc_text_secondary"
            android:textSize="13sp" />
    </ScrollView>
</LinearLayout>