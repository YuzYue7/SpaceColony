<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:layout_marginBottom="8dp"
    android:background="#EEE8F5"
    android:gravity="center_vertical">

    <CheckBox
        android:id="@+id/checkCrew"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <ImageView
        android:id="@+id/ivCrewAvatar"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginStart="6dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_pilot"
        android:contentDescription="Crew avatar" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="10dp">

        <TextView
            android:id="@+id/tvCrewName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Name"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvCrewSpec"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Specialization" />

        <TextView
            android:id="@+id/tvCrewStats"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Stats" />

        <TextView
            android:id="@+id/tvCrewLocation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Location" />
    </LinearLayout>
</LinearLayout>